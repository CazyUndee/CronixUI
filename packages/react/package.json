{
  "name": "cronixui-react",
  "version": "1.0.0",
  "description": "CronixUI React Components - TypeScript React components with dark theme",
  "keywords": [
    "react",
    "typescript",
    "ui",
    "dark-mode",
    "components",
    "design-system"
  ],
  "license": "GPL-3.0",
  "author": "CazyUndee",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens/index.js",
      "types": "./dist/tokens/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CazyUndee/CronixUI.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/CazyUndee/CronixUI/issues"
  },
  "homepage": "https://github.com/CazyUndee/CronixUI#readme"
}
