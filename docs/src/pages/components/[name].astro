---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { components, getComponent } from '../../data/spec';

export async function getStaticPaths() {
  return components.map((component) => ({
    params: { name: component.name.toLowerCase() },
    props: { component }
  }));
}

const { component } = Astro.props;
const current = getComponent(component.name) ?? component;
---

<BaseLayout title={`CronixUI - ${current.name}`} description={`CronixUI component docs for ${current.name}`}>
  <section class="panel">
    <p class="eyebrow">{current.category}</p>
    <h1>{current.name}</h1>
    <p class="lede">Prefix: <code>{current.prefix}</code></p>

    <div class="preview">
      <div class={`preview-box cn-${current.prefix}`}>
        <span>Preview shell for {current.name}</span>
      </div>
    </div>

    <h2>Props</h2>
    <div class="prop-list">
      {current.props?.length ? current.props.map((prop) => (
        <div class="prop-row">
          <code>{prop.name}</code>
          <span>{prop.type}</span>
        </div>
      )) : <p>No props defined.</p>}
    </div>

    <h2>Frameworks</h2>
    <div class="frameworks">
      <span>React</span><span>Vue</span><span>Svelte</span><span>Solid</span><span>Flutter</span><span>Python</span><span>Go</span><span>Rust</span>
    </div>
  </section>
</BaseLayout>
